# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Loaded at startup by DotNetEnv (see Program.cs). Keys use the ASP.NET Core
# "__" convention to map onto nested config (ConnectionStrings:DefaultConnection,
# Jwt:Key, ...).

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=pos_db;Username=postgres;Password=your-postgres-password

# Must be at least 32 characters (HMAC-SHA256 signing key).
Jwt__Key=replace-with-a-long-random-secret-min-32-chars
Jwt__Issuer=POSApp
Jwt__Audience=POSApp
